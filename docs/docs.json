{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Restate",
  "description": "Restate is the simplest way to build resilient applications.",
  "colors": {
    "primary": "#4752c4",
    "light": "#7a87e1",
    "dark": "#4752c4"
  },
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Rubik"
    },
    "body": {
      "family": "Manrope"
    }
  },
  "contextual": {
   "options": [
     "copy",
     "view",
     "chatgpt",
     "claude"
   ]
 },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "index",
          "quickstart",
          "concepts"
        ]
      },
      {
        "group": "Use Cases",
        "pages": [
          "use-cases/ai-agents",
          "use-cases/payment-processing",
          "use-cases/user-onboarding",
          "use-cases/background-jobs"
        ]
      },
      {
        "group": "Build",
        "pages": [
          "build/services",
          "build/functions",
          {
            "group": "Helpers",
            "pages": [
              "build/functions/helpers/durable-execution",
              "build/functions/helpers/state-management",
              "build/functions/helpers/service-communication",
              "build/functions/helpers/timing/sleep",
              "build/functions/helpers/timing/schedule",
              "build/functions/helpers/timing/awakeables",
              "build/functions/helpers/workflow-coordination"
            ]
          },
          "build/functions/error-handling",
          {
            "group": "Common Patterns",
            "href": "/build/patterns",
            "pages": [
              "build/patterns/sagas",
              "build/patterns/fan-out-fan-in", 
              "build/patterns/scheduled-tasks"
            ]
          }
        ]
      },
      {
        "group": "Operate",
        "pages": [
          "operate/deploy-scale",
          "operate/monitor-debug",
          "operate/handle-failures",
          "operate/security"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/typescript-sdk",
          "reference/go-sdk",
          "reference/java-kotlin-sdk",
          "reference/python-sdk",
          "reference/rust-sdk",
          "reference/admin-api",
          "reference/error-codes",
          "reference/server-config"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://restate.dev"
  },
  "navbar": {
    "links": [
      {
        "label": "Get Restate",
        "href": "https://restate.dev/get-restate"
      }
    ],
    "primary": {
      "type": "github",
      "label": "Github",
      "href": "https://github.com/restatedev/restate"
    }
  },
  "footer": {
    "socials": {
      "website": "https://restate.dev",
      "x": "https://x.com/restatedev",
      "github": "https://github.com/restatedev/restate",
      "linkedin": "https://linkedin.com/company/mintlify",
      "discord": "https://discord.gg/skW3AZ6uGd",
      "youtube": "https://www.youtube.com/@restatedev",
      "slack": "https://join.slack.com/t/restatecommunity/shared_invite/zt-2v9gl005c-WBpr167o5XJZI1l7HWKImA",
      "x-twitter": "https://twitter.com/restatedev",
      "bluesky": "https://bsky.app/profile/restate.dev"
    }
  }
}